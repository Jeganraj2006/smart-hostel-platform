# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Redis URL (e.g. Upstash or Local)
REDIS_URL=rediss://default:<password>@<host>:<port>

# JWT secret key for token signing (Must be a long secure string)
JWT_SECRET=your_super_secret_jwt_key_that_is_long_enough_for_hmac_sha256

# Mail sender credentials
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_smtp_api_key_or_password

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
